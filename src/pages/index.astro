---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ENHANCE.AI — PIXELS, BUT BETTER">
  
  <!-- Hero Section -->
  <section class="relative min-h-[921px] flex flex-col items-center justify-center px-6 text-center overflow-hidden" id="hero">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-primary/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="relative z-10 max-w-4xl mx-auto">
      <h1 class="text-6xl md:text-8xl font-display font-black tracking-tighter text-on-surface mb-4 neon-text-glow leading-none">
        FRAMES,<br/><span class="text-primary">BUT BETTER.</span>
      </h1>
      <p class="text-on-surface-variant text-lg md:text-xl font-label tracking-tight max-w-2xl mx-auto mb-12">
        The raw power of AI applied to your low-res artifacts. Reclaim lost detail with neural upscaling tailored for the future.
      </p>

      <!-- Centered Upload Box -->
      <div id="upload-zone" class="group relative w-full max-w-2xl mx-auto aspect-video border-2 border-dashed border-primary/40 bg-surface-container/30 backdrop-blur-sm p-8 flex flex-col items-center justify-center cursor-pointer transition-all hover:border-primary hover:bg-primary/5 neon-border-glow">
        <input type="file" id="image-upload" accept="video/*" hidden />
        <span class="material-symbols-outlined text-primary text-6xl mb-4 group-hover:scale-110 transition-transform" data-icon="upload_file">upload_file</span>
        <h3 class="font-display font-bold text-xl uppercase tracking-tighter text-on-surface mb-2">Drop your video here</h3>
        <p class="font-label text-xs uppercase tracking-widest text-on-surface-variant">MP4, WEBM, MOV (MAX 500MB)</p>
        
        <!-- Decorative Corners -->
        <div class="absolute -top-1 -left-1 w-4 h-4 border-t-2 border-l-2 border-primary"></div>
        <div class="absolute -top-1 -right-1 w-4 h-4 border-t-2 border-r-2 border-primary"></div>
        <div class="absolute -bottom-1 -left-1 w-4 h-4 border-b-2 border-l-2 border-primary"></div>
        <div class="absolute -bottom-1 -right-1 w-4 h-4 border-b-2 border-r-2 border-primary"></div>
      </div>
    </div>
  </section>

  <!-- Workspace / Editor Section (Hidden initially) -->
  <section id="workspace" class="hidden py-24 px-6 bg-surface-container-lowest/50 border-y border-outline-variant relative">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-12 gap-12 items-start">
        
        <!-- Comparison Canvas -->
        <div class="lg:col-span-8 relative group">
          <div class="absolute -inset-4 bg-primary/20 blur-2xl rounded-xl opacity-50 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative overflow-hidden rounded-lg border border-primary/30 aspect-[4/3] flex flex-col bg-[#0a0a0a]" id="compare-wrap">
            <!-- Stage: only the video area — divider must not extend into timeline controls -->
            <div id="compare-stage" class="relative flex-1 min-h-0 overflow-hidden">
              <div class="absolute inset-0 z-10 flex items-center justify-center" id="compare-before" style="clip-path: inset(0 0 0 0);">
                <canvas id="canvas-before" class="max-w-full max-h-full object-contain"></canvas>
                <div class="absolute top-4 left-4 bg-background/80 px-2 py-1 text-[10px] font-label text-on-surface-variant uppercase tracking-widest">Original</div>
              </div>

              <div class="absolute inset-0 z-20 flex items-center justify-center" id="compare-after" style="clip-path: inset(0 50% 0 0);">
                <canvas id="canvas-after" class="max-w-full max-h-full object-contain"></canvas>
                <div class="absolute top-4 right-4 bg-primary/80 px-2 py-1 text-[10px] font-label text-on-primary uppercase tracking-widest">Enhanced</div>
              </div>

              <div id="compare-divider" class="absolute top-0 bottom-0 left-1/2 w-1 bg-primary z-30 -translate-x-1/2 cursor-ew-resize flex items-center justify-center pointer-events-none">
                <div class="bg-primary p-1 rounded-full shadow-[0_0_10px_var(--app-primary)] pointer-events-auto cursor-ew-resize hover:scale-125 transition-transform">
                  <span class="material-symbols-outlined text-on-primary text-sm">unfold_more</span>
                </div>
              </div>
            </div>

            <!-- Loader -->
            <div id="loading-overlay" class="hidden absolute inset-0 z-40 bg-surface-container-lowest/80 backdrop-blur-sm flex flex-col items-center justify-center px-6">
              <span class="material-symbols-outlined text-primary text-5xl animate-spin mb-4">refresh</span>
              <p id="loading-overlay-label" class="font-display font-bold text-primary tracking-widest uppercase neon-text-glow text-center mb-4">Processing</p>
              <div id="export-progress-wrap" class="hidden w-full max-w-md">
                <div class="h-2 w-full rounded-full bg-white/10 overflow-hidden border border-white/10">
                  <div id="export-progress-bar" class="h-full w-0 rounded-full bg-primary shadow-[0_0_12px_var(--neon-glow)] transition-[width] duration-150 ease-out"></div>
                </div>
                <p id="export-progress-text" class="mt-2 text-center font-mono text-xs text-on-surface-variant tabular-nums">0%</p>
              </div>
            </div>

            <!-- Player chrome: separate row below stage so A/B divider never crosses the timeline -->
            <div
              id="player-chrome"
              class="relative z-[45] shrink-0 w-full pointer-events-none border-t border-white/10 bg-black/85 backdrop-blur-sm"
            >
              <div
                id="player-chrome-hit"
                class="pointer-events-auto bg-gradient-to-t from-black/40 to-transparent pt-3 pb-2 px-2 sm:px-3"
              >
                <!-- Scrubber -->
                <div class="relative h-1.5 mb-2 group/scrub cursor-pointer" id="scrub-track">
                  <div class="absolute inset-0 rounded-full bg-white/25"></div>
                  <div
                    id="progress-filled"
                    class="absolute left-0 top-0 bottom-0 rounded-full bg-primary shadow-[0_0_8px_var(--neon-glow)] pointer-events-none transition-[width] duration-75 ease-linear"
                    style="width: 0%"
                  ></div>
                  <div
                    id="scrub-thumb"
                    class="scrub-thumb absolute top-1/2 h-3 w-3 rounded-full bg-primary opacity-0 group-hover/scrub:opacity-100 shadow-[0_0_10px_var(--app-primary)] pointer-events-none transition-opacity"
                    style="left: 0%"
                  ></div>
                  <input
                    type="range"
                    id="timeline"
                    min="0"
                    max="1000"
                    value="0"
                    step="1"
                    aria-label="Seek timeline"
                    class="absolute inset-0 w-full h-6 -top-2 opacity-0 cursor-pointer z-10"
                  />
                </div>

                <div class="flex items-center gap-1 sm:gap-2 min-h-10">
                  <button
                    type="button"
                    id="play-pause-btn"
                    class="shrink-0 flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/10 transition-colors"
                    aria-label="Play or pause"
                  >
                    <span class="material-symbols-outlined text-3xl leading-none" id="play-pause-icon">pause</span>
                  </button>

                  <div class="font-mono text-xs sm:text-sm text-white/90 tabular-nums shrink-0 select-none">
                    <span id="time-current">0:00</span>
                    <span class="text-white/50 mx-0.5">/</span>
                    <span id="time-duration">0:00</span>
                  </div>

                  <div class="flex-1 min-w-2"></div>

                  <!-- Volume: icon + slider (expand on hover desktop, always usable on touch) -->
                  <div
                    id="volume-cluster"
                    class="flex items-center gap-1 rounded-full px-0.5 hover:bg-white/5 transition-colors"
                  >
                    <button
                      type="button"
                      id="mute-btn"
                      class="shrink-0 flex h-10 w-10 items-center justify-center rounded-full text-white hover:bg-white/10 transition-colors"
                      aria-label="Mute or unmute"
                    >
                      <span class="material-symbols-outlined text-2xl leading-none" id="mute-icon">volume_off</span>
                    </button>
                    <div class="flex items-center w-[88px] sm:w-24">
                      <input
                        type="range"
                        id="volume"
                        min="0"
                        max="100"
                        value="100"
                        step="1"
                        aria-label="Volume"
                        class="player-volume-range w-full h-1 rounded-full appearance-none cursor-pointer"
                      />
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
          </div>
        </div>

        <!-- Controls Sidebar -->
        <div class="lg:col-span-4 flex flex-col gap-8">
          <div>
            <span class="font-label text-secondary uppercase tracking-[0.3em] text-sm mb-4 block">Engine Parameters</span>
            <h2 class="text-3xl font-display font-black text-on-surface mb-6 tracking-tighter">
              MANUAL TUNE
            </h2>
            
            <div class="flex flex-col gap-6">
              <div class="w-full">
                <div class="flex justify-between mb-2">
                  <label class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Brightness</label>
                  <span id="brightness-val" class="font-label text-xs text-primary">100</span>
                </div>
                <input type="range" id="brightness" min="0" max="200" value="100" class="w-full accent-primary bg-surface-container-highest h-1 rounded-full appearance-none cursor-pointer"/>
              </div>

              <div class="w-full">
                <div class="flex justify-between mb-2">
                  <label class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Contrast</label>
                  <span id="contrast-val" class="font-label text-xs text-primary">100</span>
                </div>
                <input type="range" id="contrast" min="0" max="200" value="100" class="w-full accent-primary bg-surface-container-highest h-1 rounded-full appearance-none cursor-pointer"/>
              </div>

              <div class="w-full">
                <div class="flex justify-between mb-2">
                  <label class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Temperature</label>
                  <span id="temp-val" class="font-label text-xs text-primary">0</span>
                </div>
                <input type="range" id="temperature" min="-50" max="50" value="0" class="w-full accent-primary bg-surface-container-highest h-1 rounded-full appearance-none cursor-pointer"/>
              </div>

              <div class="w-full">
                <div class="flex justify-between mb-2">
                  <label class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Saturation</label>
                  <span id="sat-val" class="font-label text-xs text-primary">100</span>
                </div>
                <input type="range" id="saturation" min="0" max="200" value="100" class="w-full accent-primary bg-surface-container-highest h-1 rounded-full appearance-none cursor-pointer"/>
              </div>
              
              <div class="w-full">
                <div class="flex justify-between mb-2">
                  <label class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Sharpness</label>
                  <span id="sharp-val" class="font-label text-xs text-primary">0</span>
                </div>
                <input type="range" id="sharpness" min="0" max="10" value="0" class="w-full accent-primary bg-surface-container-highest h-1 rounded-full appearance-none cursor-pointer"/>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <button class="bg-surface-container border border-primary/20 text-on-surface hover:border-primary py-2 font-label text-xs uppercase tracking-widest transition-all preset-btn" data-preset="cool">Cool</button>
            <button class="bg-surface-container border border-primary/20 text-on-surface hover:border-primary py-2 font-label text-xs uppercase tracking-widest transition-all preset-btn" data-preset="warm">Warm</button>
            <button class="bg-surface-container border border-primary/20 text-on-surface hover:border-primary py-2 font-label text-xs uppercase tracking-widest transition-all preset-btn" data-preset="contrast">Punchy</button>
            <button class="bg-surface-container border border-primary/20 text-on-surface hover:border-primary py-2 font-label text-xs uppercase tracking-widest transition-all preset-btn" data-preset="bw">Mono</button>
            <button class="col-span-2 bg-surface-container border border-secondary/20 text-secondary hover:border-secondary py-2 font-label text-xs uppercase tracking-widest transition-all preset-btn" data-preset="reset">Reset</button>
          </div>

          <div class="flex flex-col gap-4 mt-4 border-t border-outline-variant pt-8">
            <button id="ai-enhance-btn" class="bg-primary text-on-primary px-6 py-3 font-display font-bold uppercase tracking-tighter hover:scale-[1.02] active:scale-[0.98] transition-all neon-border-glow">
              NEURAL UPSCALER
            </button>
            <button id="ai-colorize-btn" class="bg-surface-container border border-primary/30 text-primary px-6 py-3 font-display font-bold uppercase tracking-tighter hover:bg-primary/10 transition-all neon-border-glow">
              AI COLOR RESTORE
            </button>
            <button id="download-btn" class="bg-secondary text-on-secondary px-6 py-3 font-display font-bold uppercase tracking-tighter hover:scale-[1.02] active:scale-[0.98] transition-all secondary-glow mt-4">
              EXPORT VIDEO
            </button>
          </div>
          
        </div>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="py-24 px-6">
    <div class="max-w-7xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-display font-black text-on-surface tracking-tighter uppercase">Engine Capabilities</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6 max-w-7xl mx-auto">
      <div class="group bg-surface-container/50 border border-primary/20 p-8 transition-all hover:bg-surface-container-high hover:-translate-y-2 neon-border-glow">
        <div class="text-primary font-display font-bold text-4xl mb-6 opacity-50 group-hover:opacity-100 transition-opacity">01</div>
        <span class="material-symbols-outlined text-primary text-4xl mb-4" data-icon="speed">speed</span>
        <h3 class="text-xl font-display font-bold text-on-surface mb-3 tracking-tighter uppercase">Upscaling</h3>
        <p class="text-on-surface-variant text-sm font-body leading-relaxed">
          Expand dimensions up to 800% without losing perceptual quality. Neural filling tech creates sharp edges and realistic textures.
        </p>
      </div>
      <div class="group bg-surface-container/50 border border-secondary/20 p-8 transition-all hover:bg-surface-container-high hover:-translate-y-2 secondary-glow">
        <div class="text-secondary font-display font-bold text-4xl mb-6 opacity-50 group-hover:opacity-100 transition-opacity">02</div>
        <span class="material-symbols-outlined text-secondary text-4xl mb-4" data-icon="blur_off">blur_off</span>
        <h3 class="text-xl font-display font-bold text-on-surface mb-3 tracking-tighter uppercase">Denoising</h3>
        <p class="text-on-surface-variant text-sm font-body leading-relaxed">
          Eliminate ISO grain and JPEG artifacts while preserving the fine details that matter. Clean output for professional printing.
        </p>
      </div>
      <div class="group bg-surface-container/50 border border-tertiary/20 p-8 transition-all hover:bg-surface-container-high hover:-translate-y-2 shadow-[0_0_16px_rgba(255,224,74,0.1)]">
        <div class="text-tertiary font-display font-bold text-4xl mb-6 opacity-50 group-hover:opacity-100 transition-opacity">03</div>
        <span class="material-symbols-outlined text-tertiary text-4xl mb-4" data-icon="auto_fix_high">auto_fix_high</span>
        <h3 class="text-xl font-display font-bold text-on-surface mb-3 tracking-tighter uppercase">Restoring</h3>
        <p class="text-on-surface-variant text-sm font-body leading-relaxed">
          Breathe life into scanned photos. Fix scratches, tears, and color degradation using our advanced historical synthesis model.
        </p>
      </div>
    </div>
  </section>

</Layout>

<script>
  import anime from 'animejs';

  // State
  let currentVideo: HTMLVideoElement | null = null;
  let renderLoopId: number | null = null;
  let sliderPct = 50;
  let isSeekingTimeline = false;
  let volumeControlSupported = true;
  
  const uploadZone = document.getElementById('upload-zone')!;
  const fileInput = document.getElementById('image-upload') as HTMLInputElement;
  const heroSection = document.getElementById('hero')!;
  const workspace = document.getElementById('workspace')!;
  
  const compareStage = document.getElementById('compare-stage')!;
  const canvasBefore = document.getElementById('canvas-before') as HTMLCanvasElement;
  const canvasAfter = document.getElementById('canvas-after') as HTMLCanvasElement;
  const ctxBefore = canvasBefore.getContext('2d')!;
  const ctxAfter = canvasAfter.getContext('2d')!;
  const compareAfterEl = document.getElementById('compare-after')!;
  const dividerEl = document.getElementById('compare-divider')!;
  const loadingEl = document.getElementById('loading-overlay')!;
  const loadingLabelEl = document.getElementById('loading-overlay-label')!;
  const exportProgressWrap = document.getElementById('export-progress-wrap')!;
  const exportProgressBar = document.getElementById('export-progress-bar')!;
  const exportProgressText = document.getElementById('export-progress-text')!;
  const playPauseBtn = document.getElementById('play-pause-btn') as HTMLButtonElement;
  const playPauseIcon = document.getElementById('play-pause-icon') as HTMLElement;
  const timelineEl = document.getElementById('timeline') as HTMLInputElement;
  const timeCurrentEl = document.getElementById('time-current') as HTMLElement;
  const timeDurationEl = document.getElementById('time-duration') as HTMLElement;
  const progressFilledEl = document.getElementById('progress-filled') as HTMLElement;
  const scrubThumbEl = document.getElementById('scrub-thumb') as HTMLElement;
  const volumeEl = document.getElementById('volume') as HTMLInputElement;
  const muteBtn = document.getElementById('mute-btn') as HTMLButtonElement;
  const muteIcon = document.getElementById('mute-icon') as HTMLElement;
  const playerChromeHit = document.getElementById('player-chrome-hit')!;

  const sliders = ['brightness', 'contrast', 'temperature', 'saturation', 'sharpness'];
  const sEls: Record<string, HTMLInputElement> = {};
  const vEls: Record<string, HTMLElement> = {};

  sliders.forEach(id => {
    sEls[id] = document.getElementById(id) as HTMLInputElement;
    vEls[id] = document.getElementById(`${id === 'temperature' ? 'temp' : id === 'saturation' ? 'sat' : id === 'sharpness' ? 'sharp' : id}-val`)!;
    sEls[id].addEventListener('input', applyFilters);
  });

  function setSlider(pct: number) {
    sliderPct = Math.max(0, Math.min(100, pct));
    compareAfterEl.style.clipPath = `inset(0 ${100 - sliderPct}% 0 0)`;
    dividerEl.style.left = `${sliderPct}%`;
  }

  let dragging = false;
  function isControlTarget(target: EventTarget | null) {
    return target instanceof Element && !!target.closest('#player-chrome-hit');
  }
  function onDragStart(e: MouseEvent | TouchEvent) {
    if (isControlTarget(e.target)) return;
    dragging = true;
    e.preventDefault();
  }
  function onDragMove(e: MouseEvent | TouchEvent) {
    if (!dragging) return;
    const rect = compareStage.getBoundingClientRect();
    const clientX = 'touches' in e ? e.touches[0].clientX : (e as MouseEvent).clientX;
    setSlider(((clientX - rect.left) / rect.width) * 100);
  }
  function onDragEnd() { dragging = false; }

  compareStage.addEventListener('mousedown', onDragStart);
  compareStage.addEventListener('touchstart', onDragStart, { passive: false });
  window.addEventListener('mousemove', onDragMove);
  window.addEventListener('touchmove', onDragMove, { passive: false });
  window.addEventListener('mouseup', onDragEnd);
  window.addEventListener('touchend', onDragEnd);

  // Prevent compare-slider drag from stealing player control interactions
  playerChromeHit.addEventListener('pointerdown', (e) => e.stopPropagation());
  playerChromeHit.addEventListener('touchstart', (e) => e.stopPropagation(), { passive: true });

  let lastNonZeroVolume = 1;

  function formatTime(seconds: number) {
    if (!Number.isFinite(seconds) || seconds < 0) return '0:00';
    const total = Math.floor(seconds);
    const h = Math.floor(total / 3600);
    const m = Math.floor((total % 3600) / 60);
    const s = total % 60;
    if (h > 0) {
      return `${h}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}`;
    }
    return `${m}:${s.toString().padStart(2, '0')}`;
  }

  function syncMuteIcon() {
    if (!currentVideo) {
      muteIcon.textContent = 'volume_off';
      return;
    }
    if (currentVideo.muted) {
      muteIcon.textContent = 'volume_off';
      return;
    }
    const v = currentVideo.volume;
    if (v < 0.01) muteIcon.textContent = 'volume_mute';
    else if (v < 0.45) muteIcon.textContent = 'volume_down';
    else muteIcon.textContent = 'volume_up';
  }

  function syncVolumeSliderFromVideo() {
    if (!currentVideo) {
      volumeEl.value = '100';
      return;
    }
    volumeEl.value = String(Math.round(currentVideo.volume * 100));
  }

  function updateTransportUI() {
    if (!currentVideo) {
      timelineEl.value = '0';
      timeCurrentEl.textContent = '0:00';
      timeDurationEl.textContent = '0:00';
      playPauseIcon.textContent = 'play_arrow';
      progressFilledEl.style.width = '0%';
      scrubThumbEl.style.left = '0%';
      syncMuteIcon();
      return;
    }

    const duration = Number.isFinite(currentVideo.duration) ? currentVideo.duration : 0;
    const t = Number.isFinite(currentVideo.currentTime) ? currentVideo.currentTime : 0;
    let pct = 0;
    if (duration > 0) {
      if (isSeekingTimeline) {
        pct = Math.min(100, Math.max(0, (Number(timelineEl.value) / 1000) * 100));
      } else {
        pct = Math.min(100, Math.max(0, (t / duration) * 100));
      }
    }

    if (!isSeekingTimeline && duration > 0) {
      timelineEl.value = String(Math.round((t / duration) * 1000));
    }

    timeCurrentEl.textContent = formatTime(t);
    timeDurationEl.textContent = formatTime(duration);
    playPauseIcon.textContent = currentVideo.paused ? 'play_arrow' : 'pause';
    progressFilledEl.style.width = `${pct}%`;
    scrubThumbEl.style.left = `${pct}%`;
    syncMuteIcon();
  }

  function drawCurrentFrame() {
    if (!currentVideo) return;
    ctxBefore.clearRect(0, 0, canvasBefore.width, canvasBefore.height);
    ctxBefore.drawImage(currentVideo, 0, 0, canvasBefore.width, canvasBefore.height);
    ctxAfter.clearRect(0, 0, canvasAfter.width, canvasAfter.height);
    ctxAfter.drawImage(currentVideo, 0, 0, canvasAfter.width, canvasAfter.height);
  }

  function attachVideoListeners(vid: HTMLVideoElement) {
    const onSync = () => updateTransportUI();
    vid.addEventListener('play', onSync);
    vid.addEventListener('pause', onSync);
    vid.addEventListener('ended', onSync);
    vid.addEventListener('timeupdate', () => {
      if (!isSeekingTimeline) updateTransportUI();
    });
    vid.addEventListener('seeked', () => {
      if (currentVideo === vid && vid.paused) drawCurrentFrame();
      updateTransportUI();
    });
    vid.addEventListener('volumechange', () => {
      syncVolumeSliderFromVideo();
      syncMuteIcon();
    });
    vid.addEventListener('loadedmetadata', onSync);
    vid.addEventListener('durationchange', onSync);
  }

  muteBtn.addEventListener('click', () => {
    if (!currentVideo) return;
    if (currentVideo.muted) {
      currentVideo.muted = false;
      if (currentVideo.volume < 0.01) {
        currentVideo.volume = lastNonZeroVolume > 0 ? lastNonZeroVolume : 0.8;
        volumeEl.value = String(Math.round(currentVideo.volume * 100));
      }
      void currentVideo.play();
    } else {
      lastNonZeroVolume = currentVideo.volume > 0.01 ? currentVideo.volume : lastNonZeroVolume;
      currentVideo.muted = true;
    }
    syncVolumeSliderFromVideo();
    syncMuteIcon();
  });

  // Upload Handlers
  uploadZone.addEventListener('click', () => fileInput.click());
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('border-primary', 'bg-primary/5'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('border-primary', 'bg-primary/5'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault(); uploadZone.classList.remove('border-primary', 'bg-primary/5');
    const f = e.dataTransfer?.files?.[0]; if (f) loadMedia(f);
  });
  fileInput.addEventListener('change', e => {
    const f = (e.target as HTMLInputElement).files?.[0]; if (f) loadMedia(f);
  });

  function loadMedia(file: File) {
    const url = URL.createObjectURL(file);
    const vid = document.createElement('video');
    vid.muted = true;
    vid.volume = 1;
    vid.loop = true;
    vid.playsInline = true;
    vid.src = url;

    volumeEl.value = '100';
    lastNonZeroVolume = 1;
    volumeControlSupported = true;
    volumeEl.disabled = false;
    volumeEl.title = '';

    attachVideoListeners(vid);

    vid.onloadeddata = () => {
      currentVideo = vid;
      const originalVol = vid.volume;
      vid.volume = 0.37;
      volumeControlSupported = Math.abs(vid.volume - 0.37) < 0.02;
      vid.volume = originalVol;
      if (!volumeControlSupported) {
        volumeEl.disabled = true;
        volumeEl.title = 'This browser controls volume with hardware buttons only.';
      }
      vid.play().catch(() => {
        // Mobile browsers can block autoplay with sound.
      });
        
      // Hide hero, show workspace smoothly
      anime({
        targets: heroSection,
        opacity: 0,
        height: 0,
        duration: 500,
        easing: 'easeInOutQuad',
        complete: () => {
          heroSection.classList.add('hidden');
          workspace.classList.remove('hidden');
          workspace.style.opacity = '0';
          anime({
            targets: workspace,
            opacity: 1,
            duration: 800,
            easing: 'easeOutExpo'
          });
        }
      });

      const mw = compareStage.clientWidth || 800;
      const mh = compareStage.clientHeight || 600;
      const r = Math.min(mw / vid.videoWidth, mh / vid.videoHeight, 1);
      const w = Math.round(vid.videoWidth * r);
      const h = Math.round(vid.videoHeight * r);

      [canvasBefore, canvasAfter].forEach(c => { c.width = w; c.height = h; });

      applyFilters();
      setSlider(50);
      syncVolumeSliderFromVideo();
      updateTransportUI();
      
      if (renderLoopId) cancelAnimationFrame(renderLoopId);
      renderLoop();
    };
  }

  function renderLoop() {
    if (currentVideo && !currentVideo.paused && !currentVideo.ended) {
      drawCurrentFrame();
    }
    updateTransportUI();
    renderLoopId = requestAnimationFrame(renderLoop);
  }

  playPauseBtn.addEventListener('click', () => {
    if (!currentVideo) return;
    if (currentVideo.paused) {
      currentVideo.play().catch(() => {});
    } else {
      currentVideo.pause();
    }
    updateTransportUI();
  });

  function endTimelineSeek() {
    if (!isSeekingTimeline) return;
    isSeekingTimeline = false;
    updateTransportUI();
  }

  timelineEl.addEventListener('pointerdown', (e) => {
    isSeekingTimeline = true;
    try {
      timelineEl.setPointerCapture(e.pointerId);
    } catch {
      /* Some browsers reject capture on range inputs */
    }
  });

  function onGlobalTimelinePointerEnd(e: PointerEvent) {
    if (!isSeekingTimeline) return;
    try {
      if (timelineEl.hasPointerCapture(e.pointerId)) {
        timelineEl.releasePointerCapture(e.pointerId);
      }
    } catch {
      /* ignore */
    }
    endTimelineSeek();
  }

  document.addEventListener('pointerup', onGlobalTimelinePointerEnd, true);
  document.addEventListener('pointercancel', onGlobalTimelinePointerEnd, true);
  timelineEl.addEventListener('lostpointercapture', () => endTimelineSeek());

  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') endTimelineSeek();
  });

  timelineEl.addEventListener('input', () => {
    if (!currentVideo || !Number.isFinite(currentVideo.duration)) return;
    const pct = Number(timelineEl.value) / 1000;
    currentVideo.currentTime = pct * currentVideo.duration;
    if (currentVideo.paused) drawCurrentFrame();
    updateTransportUI();
  });
  timelineEl.addEventListener('change', () => {
    if (!currentVideo || !Number.isFinite(currentVideo.duration)) return;
    const pct = Number(timelineEl.value) / 1000;
    currentVideo.currentTime = pct * currentVideo.duration;
    if (currentVideo.paused) drawCurrentFrame();
    updateTransportUI();
  });

  volumeEl.addEventListener('input', () => {
    if (!currentVideo) return;
    if (!volumeControlSupported) return;
    const v = Math.min(1, Math.max(0, Number(volumeEl.value) / 100));
    currentVideo.volume = v;
    if (v > 0.01) {
      lastNonZeroVolume = v;
      currentVideo.muted = false;
    } else {
      currentVideo.muted = true;
    }
    syncMuteIcon();
  });
  volumeEl.addEventListener('change', () => {
    if (!currentVideo) return;
    if (!volumeControlSupported) return;
    const v = Math.min(1, Math.max(0, Number(volumeEl.value) / 100));
    currentVideo.volume = v;
    if (v > 0.01) {
      lastNonZeroVolume = v;
      currentVideo.muted = false;
    } else {
      currentVideo.muted = true;
    }
    syncMuteIcon();
  });

  function applyFilters() {
    const b = +sEls.brightness.value, c = +sEls.contrast.value, t = +sEls.temperature.value;
    const s = +sEls.saturation.value, sh = +sEls.sharpness.value;
    
    vEls.brightness.textContent = String(b); vEls.contrast.textContent = String(c);
    vEls.temperature.textContent = String(t); vEls.saturation.textContent = String(s);
    vEls.sharpness.textContent = String(sh);

    let sepia = 0, hue = 0;
    if (t > 0) sepia = t; else if (t < 0) hue = t * -2;
    const sharpenVal = sh > 0 ? `contrast(${100 + sh * 5}%) saturate(${100 + sh * 3}%)` : '';
    const filterStr = `brightness(${b}%) contrast(${c}%) saturate(${s}%) sepia(${sepia}%) hue-rotate(${hue}deg) ${sharpenVal}`;

    canvasAfter.style.filter = filterStr;
  }

  // Presets and AI
  const presets: Record<string, {b:number,c:number,t:number,s:number,sh:number}> = {
    cool: {b:105,c:110,t:-20,s:110,sh:2},
    warm: {b:95,c:115,t:30,s:120,sh:0},
    contrast: {b:100,c:160,t:0,s:100,sh:4},
    bw: {b:100,c:120,t:0,s:0,sh:1},
    reset: {b:100,c:100,t:0,s:100,sh:0},
  };

  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const p = presets[(btn as HTMLElement).dataset.preset!];
      if (!p) return;
      const proxy = { b: Number(sEls.brightness.value), c: Number(sEls.contrast.value), t: Number(sEls.temperature.value), s: Number(sEls.saturation.value), sh: Number(sEls.sharpness.value) };
      anime({
        targets: proxy, b: p.b, c: p.c, t: p.t, s: p.s, sh: p.sh,
        duration: 300, easing: 'linear',
        update: () => {
          sEls.brightness.value = proxy.b.toString(); sEls.contrast.value = proxy.c.toString();
          sEls.temperature.value = proxy.t.toString(); sEls.saturation.value = proxy.s.toString();
          sEls.sharpness.value = proxy.sh.toString(); applyFilters();
        }
      });
    });
  });

  function runAI(params: any) {
    if (!currentVideo) return;
    exportProgressWrap.classList.add('hidden');
    loadingLabelEl.textContent = 'Processing…';
    loadingEl.classList.remove('hidden');
    setTimeout(() => {
      loadingEl.classList.add('hidden');
      const proxy = { b: Number(sEls.brightness.value), c: Number(sEls.contrast.value), t: Number(sEls.temperature.value), s: Number(sEls.saturation.value), sh: Number(sEls.sharpness.value) };
      anime({
        targets: proxy, ...params,
        duration: 300, easing: 'linear',
        update: () => {
          sEls.brightness.value = proxy.b.toString(); sEls.contrast.value = proxy.c.toString();
          sEls.temperature.value = proxy.t.toString(); sEls.saturation.value = proxy.s.toString();
          sEls.sharpness.value = proxy.sh.toString(); applyFilters();
        }
      });
    }, 1500);
  }

  document.getElementById('ai-enhance-btn')!.addEventListener('click', () => runAI({b:108,c:120,s:115,t:0,sh:5}));
  document.getElementById('ai-colorize-btn')!.addEventListener('click', () => runAI({b:102,c:110,s:130,t:25,sh:1}));

  document.getElementById('download-btn')!.addEventListener('click', async () => {
    if (!currentVideo) return;

    const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;
    const originalText = downloadBtn.textContent;
    downloadBtn.disabled = true;
    downloadBtn.textContent = 'EXPORTING...';
    loadingEl.classList.remove('hidden');
    loadingLabelEl.textContent = 'Exporting video…';
    exportProgressWrap.classList.remove('hidden');
    exportProgressBar.style.width = '0%';
    exportProgressText.textContent = '0%';

    const exportCanvas = document.createElement('canvas');
    exportCanvas.width = canvasAfter.width;
    exportCanvas.height = canvasAfter.height;
    const exportCtx = exportCanvas.getContext('2d');
    if (!exportCtx) {
      loadingEl.classList.add('hidden');
      exportProgressWrap.classList.add('hidden');
      downloadBtn.disabled = false;
      downloadBtn.textContent = originalText;
      return;
    }

    let exportRaf: number | null = null;
    let exportProgressRaf: number | null = null;
    const drawExportFrame = () => {
      exportCtx.clearRect(0, 0, exportCanvas.width, exportCanvas.height);
      exportCtx.filter = canvasAfter.style.filter || 'none';
      exportCtx.drawImage(currentVideo!, 0, 0, exportCanvas.width, exportCanvas.height);
      exportRaf = requestAnimationFrame(drawExportFrame);
    };

    const tickExportProgress = () => {
      const v = currentVideo;
      if (v && Number.isFinite(v.duration) && v.duration > 0) {
        const pct = Math.min(88, (v.currentTime / v.duration) * 88);
        exportProgressBar.style.width = `${pct}%`;
        exportProgressText.textContent = `${Math.round(pct)}%`;
      }
      exportProgressRaf = requestAnimationFrame(tickExportProgress);
    };

    const canvasStream = exportCanvas.captureStream(30);
    const audioTracks = currentVideo.captureStream().getAudioTracks();
    if (audioTracks[0]) canvasStream.addTrack(audioTracks[0]);

    const mimeType = MediaRecorder.isTypeSupported('video/webm;codecs=vp9,opus')
      ? 'video/webm;codecs=vp9,opus'
      : 'video/webm';
    const recorder = new MediaRecorder(canvasStream, { mimeType });
    const chunks: Blob[] = [];
    recorder.ondataavailable = (event) => {
      if (event.data.size > 0) chunks.push(event.data);
    };

    const originalLoop = currentVideo.loop;
    const originalMuted = currentVideo.muted;
    const originalTime = currentVideo.currentTime;
    const wasPaused = currentVideo.paused;

    try {
      currentVideo.loop = false;
      currentVideo.currentTime = 0;
      currentVideo.muted = false;
      drawExportFrame();
      exportProgressRaf = requestAnimationFrame(tickExportProgress);
      recorder.start(250);
      await currentVideo.play();

      await new Promise<void>((resolve) => {
        const onEnded = () => {
          currentVideo?.removeEventListener('ended', onEnded);
          resolve();
        };
        currentVideo?.addEventListener('ended', onEnded);
      });

      exportProgressBar.style.width = '90%';
      exportProgressText.textContent = '90%';
      loadingLabelEl.textContent = 'Finalizing encode…';

      recorder.stop();
      await new Promise<void>((resolve) => {
        recorder.onstop = () => resolve();
      });

      exportProgressBar.style.width = '96%';
      exportProgressText.textContent = '96%';
      loadingLabelEl.textContent = 'Preparing download…';

      const blob = new Blob(chunks, { type: mimeType });
      const exportUrl = URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = exportUrl;
      link.download = 'enhancevideo-export.webm';
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(exportUrl);

      exportProgressBar.style.width = '100%';
      exportProgressText.textContent = '100%';
    } catch (err) {
      alert('Export failed on this browser. Try desktop Chrome/Edge for reliable video export.');
    } finally {
      if (exportRaf) cancelAnimationFrame(exportRaf);
      if (exportProgressRaf) cancelAnimationFrame(exportProgressRaf);
      currentVideo.loop = originalLoop;
      currentVideo.muted = originalMuted;
      currentVideo.currentTime = Math.min(originalTime, Number.isFinite(currentVideo.duration) ? currentVideo.duration : originalTime);
      if (!wasPaused) currentVideo.play().catch(() => {});
      exportProgressWrap.classList.add('hidden');
      loadingEl.classList.add('hidden');
      downloadBtn.disabled = false;
      downloadBtn.textContent = originalText;
      updateTransportUI();
    }
  });
</script>

